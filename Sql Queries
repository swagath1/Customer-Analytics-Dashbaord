--Compare each customer's spending with the average spending of customers from the same country.

select 
	 customer_id,
	 name,
	 country,
	 total_spend_usd,
	 avg(total_spend_usd)over(partition by country) country_avg_spending
from ecommerce;

--Calculate monthly revenue, compare it with the previous month's revenue, and compute the Month-over-Month (MoM) revenue growth percentage.

with cte as (
		select 
		      year(last_order_date) order_year,
			  month(last_order_date) order_month,
			  sum(total_spend_usd) total_revenue
        from ecommerce
		where last_order_date is not null
		group by year(last_order_date),month(last_order_date)
		)
		select  
		      order_year,
			  order_month,
			  total_revenue,
			  lag(total_revenue)over(order by order_year,order_month) prev_revenue,

			  round((total_revenue-lag(total_revenue)over(order by order_year,order_month))*100.0/
			  lag(total_revenue)over(order by order_year,order_month),2) growth_percentage

		from cte
		;
--Compare each month's revenue with the next month's revenue and identify whether revenue is expected to increase or decrease in the following month.--

with cte as (
				select 
					  year(last_order_date) order_year,
					  month(last_order_date) order_month,
					  sum(total_spend_usd) total_revenue
				from ecommerce
				group by year(last_order_date),month(last_order_date)
		),
		cte1 as (
				select order_year,order_month,total_revenue,
				lead(total_revenue)over(order by order_year,order_month) next_revenue
				from cte
		 )
			   select 
					 order_year,order_month,
					 total_revenue,next_revenue,
					 case when next_revenue>total_revenue then 'increase'
						  when next_revenue<total_revenue then 'decrease'
					 else 'no change'
					 end as revenue_trend
				from cte1;

--Segment customers into four revenue-based tiers using spending quartiles to support targeted marketing, loyalty programs, and customer retention strategies

with cte as (
	select 
	customer_id,name,total_spend_usd,
	ntile(4)over(order by total_spend_usd desc) quartile
	from ecommerce 
)
	select customer_id,name,total_spend_usd,quartile,
	case when quartile=1 then 'Top 25% customers'
		 when quartile=2 then 'Upper_middle_class'
		 when quartile=3 then 'Lower_middle-class'
	else 'bottom 25% customers'
	end as Customer_segment
	from cte;

--Compare each customer's spending with the highest spending customer in their country
			
with cte as (
select customer_id,country,sum(total_spend_usd) total_revenue
from ecommerce
group by customer_id,country
)
select customer_id,country,total_revenue,
max(total_revenue)over(partition by country) highest_revenue
from cte;

--Rank customers based on spending percentile.

with cte as (
select customer_id,name,total_spend_usd,
percent_rank()over(order by total_spend_usd desc) percentage_growth
from ecommerce
)
select customer_id,name,total_spend_usd,
round(percentage_growth*100,2) growth_percentage,
case when percentage_growth>=0.90 then 'top 10%'
     when percentage_growth>=0.75 then 'top 25%'
	 when percentage_growth>=0.50 then 'top 50%'
     else 'bottom 25%'
end as rankings
from cte
order by growth_percentage desc;
