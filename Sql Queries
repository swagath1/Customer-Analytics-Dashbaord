
use flagship;

--How many customers are there in each country?
select country,count(customer_id) total_people
from Ecommerce
group by country;

--What is the total revenue generated by each country?
select country,concat(round(sum(total_spend_usd),2),'$') total_amount
from Ecommerce
group by country;

--Total Orders based on Country
select country,sum(total_orders) total_orders
from Ecommerce
group by country;

--Which country has the highest average customer spending?
select country,concat(round(avg(total_spend_usd),2),'$') avg_spend
from Ecommerce
group by country
order by avg_spend desc;

--Which country has most repeated customers?

select top 1 country,sum(case when is_repeat_customer=1 then 1
      else 0
    end) repeated_customers
from Ecommerce
group by country;

--Which country has highest average tenure?

select country,round(avg(customer_tenure),2) avg_tenure
from Ecommerce
group by country
order by avg_tenure desc;

--Which payment method generates highest revenue?

select preferred_payment,round(sum(total_spend_usd),2) revenue
from Ecommerce
group by preferred_payment
order by revenue desc;

--Which payment method has the highest average order value?

select preferred_payment,
round(avg(avg_order_value),2) avg_value
from Ecommerce
group by preferred_payment
order by avg_value desc;

--Which country has the highest abandonment rate?

select  top 1 
    country,
    count(case when has_abandoned_cart=1 then 1 end) * 100.0/ count(*) as abandonment_rate_percent
from ecommerce
group by country
order by abandonment_rate_percent desc

--Who hasn't purchased in the last 180 days?

select name,
recency
from Ecommerce
where recency>=180
order by recency desc;

--Intermediate Questions

--Which countries generated more than $500,000 in revenue?

select country,round(sum(total_spend_usd),2) total_revenue
from Ecommerce
group by country
having sum(total_spend_usd)>500000;

--Which age groups have an average spending greater than $300?

select 
    age_group,avg(total_spend_usd) avg_spend
	from Ecommerce
	group by age_group
	having avg(total_spend_usd)>300;

--Categorize customers as High, Medium, and Low spenders using SQL instead of the Python feature

select 
      customer_id,
	  sum(total_spend_usd) revenue,
	  Case when sum(total_spend_usd)>=1500 then 'High Spender'
	       when sum(total_spend_usd)>=500 then 'Medium Spender'
			   else 'Low Spender'
		  end as Spending_category
	 from Ecommerce
	 group by customer_id
	 order by revenue desc;

--How many repeat and non-repeat customers are there in each country?

select 
      country,
	  sum(case when is_repeat_customer=1 then 1 else 0 end) as repeated_customers,
	  sum(case when is_repeat_customer=0 then 1 else 0 end) as non_repeated_customers
from ecommerce
group by country;


--Which payment methods are preferred by VIP Customers?

select preferred_payment,
       count(customer_id) total
from Ecommerce
where tenure_category in ('VIP Customer','Loyal Customer')
group by preferred_payment 
order by total desc;

--Which device generates the highest revenue in each country?

with cte as(
select 
     country,preferred_device_ord as device,
	 sum(total_spend_usd) total_revenue,
	 row_number()over(partition by country order by sum(total_spend_usd) desc) rn
from ecommerce
group by country,preferred_device_ord

  )
  select
       country,device,total_revenue
   from cte 
   where total_revenue>0 and rn=1

--Which customers have not purchased in the last 180 days?

select 
     customer_id,name,
	 last_order_date,
	 datediff(day,last_order_date,(select max(last_order_date) from ecommerce)) as recency
from ecommerce
where datediff(day,last_order_date,(select max(last_order_date) from ecommerce))>180;

--Find the average customer tenure for each spending category.

select 
       spending_category,
	   avg(customer_tenure) avg_tenure
from ecommerce
group by spending_category
having avg(customer_tenure)>0;


--Which countries have more than 500 repeat customers?

select 
      country,
	  sum(case when is_repeat_customer=1 then 1
	  end )as repeated_customers
from ecommerce
group by country
having sum(case when is_repeat_customer=1 then 1
	  end )>500
	  order by repeated_customers desc;

