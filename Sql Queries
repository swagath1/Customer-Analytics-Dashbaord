-- Rank all countries based on total revenue.

with cte as (		
			select country,
			sum(total_spend_usd) total_spend,
			rank()over(order by sum(total_spend_usd) desc) country_rank
			from ecommerce
			group by country
		)
		select country,total_spend,country_rank
		from cte 
		
-- Rank customers within each spending category based on total spending.

	SELECT
    customer_id,
    name,
    spending_category,
    total_spend_usd,
    DENSE_RANK() OVER
    (
        PARTITION BY spending_category
        ORDER BY total_spend_usd DESC
    ) AS spending_rank
FROM Ecommerce
ORDER BY
    spending_category,
    spending_rank;

